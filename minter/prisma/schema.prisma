generator client {
  provider = "prisma-client-js"
}

// Railway: добавьте плагин PostgreSQL — DATABASE_URL подставится сам
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Jetton {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  status          String   @default("draft")

  name            String
  symbol          String
  decimals        Int      @default(9)
  description     String   @default("")
  image           String   @default("")

  adminAddress    String?
  /// Address embedded in on-chain metadata URI path (API route key)
  minterAddress   String?  @unique
  /// Actual deployed jetton master on-chain (may differ from minterAddress)
  deployedMinterAddress String? @unique
  network         String?

  merkleRoot      String
  airdropBoc      String
  recipientCount  Int
  totalSupply     String
}
